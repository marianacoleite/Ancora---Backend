# Copiar para ".env" e preencher com os valores do teu projeto.
# Supabase: https://supabase.com/dashboard → o teu projeto → Project Settings → API

# ---------------------------------------------------------------------------
# Obrigatório no backend (este repositório)
# ---------------------------------------------------------------------------

# "Project URL" na página API (ex.: https://abcdefgh.supabase.co)
SUPABASE_URL=

# "service_role" (secret) — só no servidor; nunca no frontend nem em repositórios públicos.
# Com esta chave o backend ignora RLS; trata como password.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string Postgres (Settings → Database). Usada por scripts que aplicam SQL (ex.: test:record).
# Preferir URL direta porta 5432 para DDL; o pooler 6543 / pgbouncer não aceita CREATE TABLE.
DATABASE_URL=

# Opcional — só se DATABASE_URL for o pooler: URI direta (porta 5432) para migrações locais.
# SUPABASE_DIRECT_DATABASE_URL=

# ---------------------------------------------------------------------------
# Opcional — servidor Express
# ---------------------------------------------------------------------------

# Porta (predefinição: 3000)
# PORT=3000

# CORS: uma ou várias origens separadas por vírgula (sem barra final).
# O servidor também inclui automaticamente FRONTEND_URL e FRONTEND_LOCAL_URL, se definidos.
# Produção (Vercel): https://ancora-frontend.vercel.app
# Dev (Vite): http://localhost:5173
# CORS_ORIGIN=https://ancora-frontend.vercel.app,http://localhost:5173

# URL pública do frontend (usada também para CORS)
# FRONTEND_URL=https://ancora-frontend.vercel.app

# URL do frontend em desenvolvimento (usada também para CORS), ex.: Vite ou outra porta
# FRONTEND_LOCAL_URL=http://localhost:5173

# Opcional mas recomendado para login/register:
# chave "anon" usada pelo backend para signIn/signUp.
# Se ausente, o backend usa service_role.
# SUPABASE_ANON_KEY=
# ---------------------------------------------------------------------------
# Opcional — npm run seed (workspace de exemplo)
# ---------------------------------------------------------------------------

# UUID de um utilizador criado em Authentication → Users (o mesmo que aparece em auth.users)
# ANCORA_SEED_USER_ID=

# ---------------------------------------------------------------------------
# Referência — frontend (não é usado por este backend Node)
# No dashboard: "anon" / "public" — segura com RLS; pode ir para o browser.
# SUPABASE_ANON_KEY=
