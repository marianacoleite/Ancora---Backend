{
  "name": "ancora-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend Ancora — tipos e integração Supabase (Postgres)",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:supabase": "vitest run src/test/supabase-connection.test.ts",
    "test:record": "npm run build && node dist/scripts/recordTestRun.js",
    "test:watch": "vitest",
    "seed": "npm run build && node dist/scripts/seedWorkspace.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
